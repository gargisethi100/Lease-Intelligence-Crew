# ============================================================
# Lease Intelligence Crew — environment template
# Copy this file to ".env" and put REAL values there. ".env" is
# gitignored; THIS template is committed and must never hold secrets.
# ============================================================

# --- Provider switches (the provider-agnostic seam) ---------
# Chat model and embeddings are chosen INDEPENDENTLY on purpose:
# some providers do only one (Anthropic has no embeddings API);
# Azure and Gemini do both.
# PROVIDER    -> chat model:  azure | bedrock | gemini | anthropic
# EMBEDDINGS  -> embeddings:  azure | gemini | huggingface
PROVIDER=bedrock
EMBEDDINGS=gemini

# --- AWS Bedrock (Claude Haiku via Bedrock) -----------------
# Your Bedrock API key is a bearer token (read from the env var below).
# Set the region where you enabled model access. Enable "Claude Haiku 4.5"
# in the Bedrock console first. Only used when PROVIDER=bedrock.
AWS_BEARER_TOKEN_BEDROCK=
AWS_REGION=us-east-1
BEDROCK_MODEL_ID=us.anthropic.claude-haiku-4-5-20251001-v1:0

# --- Google Gemini (chat + embeddings) ----------------------
# Get a key at https://aistudio.google.com  (click "Get API key").
# Used when PROVIDER=gemini and/or EMBEDDINGS=gemini.
GOOGLE_API_KEY=
GOOGLE_CHAT_MODEL=gemini-flash-latest
GOOGLE_EMBEDDING_MODEL=models/gemini-embedding-001

# --- Azure OpenAI (interview target / production) -----------
# A "deployment" is your own named instance of a model inside the
# Azure resource; you call the deployment name, not the model name.
AZURE_OPENAI_ENDPOINT=https://YOUR-RESOURCE.openai.azure.com/
AZURE_OPENAI_API_KEY=
OPENAI_API_VERSION=2024-10-21
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-4o
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small

# --- Anthropic (optional alternative chat provider) ---------
# Only used when PROVIDER=anthropic.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5

# --- HuggingFace embeddings (optional local fallback) -------
# Only used when EMBEDDINGS=huggingface. Runs offline, no key needed.
HF_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# --- Tavily (Market Researcher web search) ------------------
TAVILY_API_KEY=

# --- LangSmith (tracing on every run) -----------------------
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=lease-intelligence-crew
