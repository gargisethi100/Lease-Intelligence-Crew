# ============================================================
# Lease Intelligence Crew — environment template
# Copy this file to ".env" and put REAL values there. ".env" is
# gitignored; THIS template is committed and must never hold secrets.
# ============================================================

# --- Provider switches (the provider-agnostic seam) ---------
# Chat model and embeddings are chosen INDEPENDENTLY on purpose:
# the fallback chat provider (Anthropic) has no embeddings API.
# PROVIDER    -> chat model:  azure | anthropic
# EMBEDDINGS  -> embeddings:  azure | huggingface
PROVIDER=azure
EMBEDDINGS=azure

# --- Azure OpenAI (primary) ---------------------------------
# A "deployment" is your own named instance of a model inside the
# Azure resource; you call the deployment name, not the model name.
AZURE_OPENAI_ENDPOINT=https://YOUR-RESOURCE.openai.azure.com/
AZURE_OPENAI_API_KEY=
OPENAI_API_VERSION=2024-10-21
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-4o
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small

# --- Anthropic (fallback chat provider) ---------------------
# Only used when PROVIDER=anthropic. Confirm the current model id
# when you create your key.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5

# --- HuggingFace embeddings (fallback, local & free) --------
# Only used when EMBEDDINGS=huggingface. Runs offline, no key needed.
HF_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# --- Tavily (Market Researcher web search) ------------------
TAVILY_API_KEY=

# --- LangSmith (tracing on every run) -----------------------
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=lease-intelligence-crew
